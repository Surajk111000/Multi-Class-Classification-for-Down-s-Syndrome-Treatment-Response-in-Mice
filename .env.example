# Example environment configuration
# Copy this file to .env and update values as needed

# API Configuration
API_TITLE=Mice Protein Expression Classification API
API_VERSION=1.0.0
LOG_LEVEL=INFO

# Server
HOST=0.0.0.0
PORT=8000
WORKERS=4

# Data paths
TRAIN_DATA_URL=https://www.ee.iitb.ac.in/~asethi/Dump/MouseTrain.csv
TEST_DATA_URL=https://www.ee.iitb.ac.in/~asethi/Dump/MouseTest.csv
MODELS_DIR=models/saved_models

# Model parameters
PCA_COMPONENTS=37
CV_FOLDS=5
RANDOM_STATE=42
USE_GRIDSEARCH=true

# CORS Configuration
CORS_ORIGINS=*
CORS_ALLOW_CREDENTIALS=true

# Database (if needed for future use)
# DATABASE_URL=sqlite:///./test.db
